{{- $personal := promptBool "Personal" (index .chezmoi.config.data "personal" | default false) -}}
{{- $gitname := promptString "Git: Name" (index .chezmoi.config.data "gitname" | default "") -}}
{{- $gitemail := promptString "Git: Email" (index .chezmoi.config.data "gitemail" | default "") -}}
{{- $gitsigningkey := promptString "Git: GPG signing key ID" (index .chezmoi.config.data "gitsigningkey" | default "") -}}
{{- $kubernetes := promptBool "Add Kubernetes" (index .chezmoi.config.data "kubernetes" | default false) -}}
{{- $desktop := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $desktop = eq (trim (output "systemctl" "get-default")) "graphical.target" -}}
{{- end -}}
sourceVCS:
  autoCommit: true
merge:
  command: nvim
  args:
    - -d
data:
  personal: {{ $personal }}
  gitname: "{{ $gitname }}"
  gitemail: "{{ $gitemail }}"
  gitsigningkey: "{{ $gitsigningkey }}"
  kubernetes: {{ $kubernetes }}
  desktop: {{ $desktop }}
