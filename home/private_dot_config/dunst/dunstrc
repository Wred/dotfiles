# Dunst config — Catppuccin Mocha + Papirus-Dark icons
# https://dunst-project.org/documentation/

[global]
    ### Display ###
    follow = none
    monitor = 0

    ### Geometry ###
    width = (200, 400)
    height = (0, 300)
    origin = top-right
    offset = (20, 60)
    scale = 0
    notification_limit = 5

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 360
    progress_bar_corner_radius = 4
    progress_bar_corners = all

    ### Appearance ###
    corner_radius = 10
    corners = all
    frame_width = 2
    frame_color = "#89b4fa"
    gap_size = 6
    separator_height = 0
    separator_color = frame
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 12
    transparency = 0

    ### Icons ###
    icon_position = left
    icon_theme = Papirus-Dark, Papirus, Adwaita
    enable_recursive_icon_lookup = true
    min_icon_size = 32
    max_icon_size = 48
    icon_corner_radius = 6
    icon_corners = all

    ### Text ###
    font = Sans 13
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    word_wrap = yes
    ellipsize = middle
    show_age_threshold = 60
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    indicate_hidden = yes

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Misc ###
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    sort = urgency_descending
    enable_posix_regex = true

    ### Wayland ###
    force_xwayland = false
    layer = overlay

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false
    pause_on_mouse_over = true

# Catppuccin Mocha palette:
#   Base:     #1e1e2e   Surface0: #313244   Surface2: #585b70
#   Text:     #cdd6f4   Subtext1: #bac2de   Overlay0: #6c7086
#   Blue:     #89b4fa   Red:      #f38ba8   Peach:    #fab387
#   Yellow:   #f9e2af   Green:    #a6e3a1

[urgency_low]
    background = "#313244"
    foreground = "#bac2de"
    frame_color = "#585b70"
    timeout = 6
    default_icon = dialog-information

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 8
    default_icon = dialog-information

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#f38ba8"
    timeout = 0
    default_icon = dialog-warning
